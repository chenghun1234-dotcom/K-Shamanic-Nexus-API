          },
          "category": {
            "type": "string",
            "title": "Category"
          },
          "region": {
            "type": "string",
            "title": "Region"
          },
          "danger_level": {
            "type": "string",
            "title": "Danger Level"
          },
          "trigger": {
            "type": "string",
            "title": "Trigger"
          },
          "weakness": {
