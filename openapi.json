    "/divination-logic": {
      "get": {
        "summary": "Get Divination Matching",
        "operationId": "get_divination_matching_divination_logic_get",
        "parameters": [
          {
            "name": "saju_element",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Saju Element"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DivinationMatch"
