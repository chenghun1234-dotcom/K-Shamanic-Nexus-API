          "name": {
            "type": "string",
            "title": "Name"
          },
          "purpose": {
            "type": "string",
            "title": "Purpose"
          },
          "ingredients": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Ingredients"
          },
          "steps": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Steps"
          },
          "risk_level": {
            "type": "string",
